# Frontend environment
# Optional: point frontend to deployed backend API base URL.
# Example: https://your-backend-domain.com/api
VITE_API_BASE_URL=/api
VITE_MAPTILER_KEY=ToZD5AZBVN7KuUY6y6eN

# Firebase Phone Auth (client-side — these are public-safe project identifiers)
# Get from: Firebase Console → Project Settings → Your apps → Web app → SDK config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id


# Bhashini — MeitY national language AI (all 22 Indian languages natively)
# Register free at https://bhashini.gov.in → get userID + API key
# Without these, Tier-2 languages (Maithili, Bodo, Urdu etc.) fall back to Sarvam Hindi bridge
BHASHINI_USER_ID=your_bhashini_user_id
BHASHINI_API_KEY=your_bhashini_api_key
